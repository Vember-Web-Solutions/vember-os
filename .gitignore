.env
.envrc
*.key
*.pem
*.pub
vault.db
secrets/
.pypirc

# =================================================================
# PYTHON & ENVIRONMENT
# =================================================================
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.venv/
env/
ENV/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# =================================================================
# DOCKER & DATABASE
# =================================================================
# Ignore local database storage and logs
pgdata/
data/
*.log
docker-compose.override.yml
.docker-log/

# =================================================================
# DEVELOPMENT TOOLS
# =================================================================
# JetBrains / PyCharm
.idea/

# VS Code
.vscode/
*.code-workspace

# Cursor AI
.cursorignore
.cursorindexingignore

# Unit test / coverage reports
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# =================================================================
# SYSTEM JUNK
# =================================================================
.DS_Store
Thumbs.db
